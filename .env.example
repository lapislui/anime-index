# ==============================================================================
# Anime Index - Environment Configuration Template
# Copy this file to '.env' and fill in your values.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Database Configuration
# ------------------------------------------------------------------------------
# For PostgreSQL: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
# For SQLite (local dev): file:./dev.db
DATABASE_URL="postgresql://neondb_owner:npg_Nl0fZGEjxC5T@ep-odd-math-ap6pp302-pooler.c-7.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ------------------------------------------------------------------------------
# 2. Passkey / WebAuthn Configuration
# ------------------------------------------------------------------------------
# NEXT_PUBLIC_RP_ID must match the exact hostname (domain name) of your deployment.
# NEXT_PUBLIC_ORIGIN must match the full web URL (including protocol and port if any).
# For Local Development:
NEXT_PUBLIC_RP_ID="localhost"
NEXT_PUBLIC_ORIGIN="http://localhost:3000"

# For Vercel Production Environment:
# NEXT_PUBLIC_RP_ID="anime-index2.vercel.app"
# NEXT_PUBLIC_ORIGIN="https://anime-index2.vercel.app"

# ------------------------------------------------------------------------------
# 3. SMTP Configuration (Google SMTP / Gmail / SMTP Relay)
# ------------------------------------------------------------------------------
# If left unconfigured, One-Time Passcodes (OTP) will fall back to logging in the 
# server terminal instead of sending an email (perfect for development).
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Anime Index <your-email@gmail.com>"

# ------------------------------------------------------------------------------
# 4. Optional Custom Streaming API Base URLs
# ------------------------------------------------------------------------------
CONSUMET_API_URL="https://api.consumet.org"
ANIKOTO_API_URL="https://anikotoapi.site"

# ------------------------------------------------------------------------------
# 5. OAuth Single Sign-On (SSO) Credentials
# ------------------------------------------------------------------------------
# Provide client ID and secret to enable login/connection buttons for each service.
# Unconfigured providers will automatically appear in a visual disabled/inactive state in the UI.
# Callback URI pattern: {NEXT_PUBLIC_ORIGIN}/api/auth/sso/{provider}/callback

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Microsoft OAuth
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""

# Discord OAuth
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# Facebook OAuth
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
