// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String?
  otpCode        String?
  otpExpiresAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  animes         Anime[]
  games          Game[]
  movies         Movie[]
  passkeys       Passkey[]
  sessions       Session[]
  googleId       String?   @unique
  githubId       String?   @unique
  microsoftId    String?   @unique
  discordId      String?   @unique
  facebookId     String?   @unique
  shareDashboard Boolean   @default(false)
  shareToken     String    @unique @default(cuid())
  shareAnime     Boolean   @default(true)
  shareGames     Boolean   @default(true)
  shareMovies    Boolean   @default(true)
  shareActivity  Boolean   @default(true)
  shareTags      Boolean   @default(true)
  following      Follow[]  @relation("Following")
  followers      Follow[]  @relation("Followers")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
}

model Passkey {
  id           String @id @default(cuid())
  credentialId String @unique
  publicKey    String
  counter      Int
  userId       String
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
}

model Anime {
  id          String    @id @default(cuid())
  title       String
  description String?
  coverImage  String?
  status      String    @default("watching") // watching, completed, dropped, planned
  year        Int?
  format      String?
  genres      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  episodes    Episode[]
  tags        Tag[]     @relation("AnimeToTag")
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Episode {
  id        String   @id @default(cuid())
  number    Int
  title     String
  story     String   // Full story text (supports long content)
  animeId   String
  anime     Anime    @relation(fields: [animeId], references: [id], onDelete: Cascade)
  media     Media[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([animeId, number])
}

model Media {
  id        String   @id @default(cuid())
  url       String
  type      String   // "image" or "clip"
  caption   String?
  order     Int      @default(0)
  episodeId String
  episode   Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Tag {
  id     String  @id @default(cuid())
  name   String
  type   String  @default("anime") // "anime", "game", "movie"
  color  String  @default("#6366f1") // Default indigo color
  animes Anime[] @relation("AnimeToTag")
  games  Game[]  @relation("GameToTag")
  movies Movie[] @relation("MovieToTag")

  @@unique([name, type])
}

model Game {
  id          String    @id @default(cuid())
  title       String
  description String?
  coverImage  String?
  status      String    @default("playing") // played, playing, backlog, cant_play
  year        Int?
  format      String?   // Platform / Format (e.g. PC, PS5, Xbox, Switch, Mobile)
  genres      String?   // Comma-separated genres
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags        Tag[]     @relation("GameToTag")
  chapters    Chapter[]
}

model Chapter {
  id        String      @id @default(cuid())
  number    Int
  title     String
  story     String      // Full story breakdown text
  gameId    String
  game      Game        @relation(fields: [gameId], references: [id], onDelete: Cascade)
  media     GameMedia[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([gameId, number])
}

model GameMedia {
  id        String   @id @default(cuid())
  url       String
  type      String   // "image" or "clip"
  caption   String?
  order     Int      @default(0)
  chapterId String
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Movie {
  id          String      @id @default(cuid())
  title       String
  description String?
  coverImage  String?
  status      String      @default("watching") // watching, completed, dropped, planned
  year        Int?
  format      String?
  genres      String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  tags        Tag[]       @relation("MovieToTag")
  parts       MoviePart[]
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MoviePart {
  id        String       @id @default(cuid())
  number    Int
  title     String
  story     String       // Full story breakdown text
  movieId   String
  movie     Movie        @relation(fields: [movieId], references: [id], onDelete: Cascade)
  media     MovieMedia[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([movieId, number])
}

model MovieMedia {
  id          String    @id @default(cuid())
  url         String
  type        String    // "image" or "clip"
  caption     String?
  order       Int       @default(0)
  moviePartId String
  moviePart   MoviePart @relation(fields: [moviePartId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

